# 프론트(브라우저)가 호출할 백엔드 API 베이스 주소.
# api.ts 가 `${NEXT_PUBLIC_API_URL}/api` 로 요청합니다. 빈 값이면 동일 출처(/api).
#
# 단계별 전환(이 값만 바꾸면 됨):
#  - 로컬 백엔드:          http://localhost:3001
#  - Vercel 배포(현재):    https://taco-backend-omega.vercel.app   ← 운영 백엔드
#
# 로컬 사용: cp .env.example .env.local
# 전체 URL 목록: docs/URLS.md
NEXT_PUBLIC_API_URL=http://localhost:3001
