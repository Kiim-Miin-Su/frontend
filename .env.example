# 프론트(브라우저)가 호출할 백엔드 API 베이스 주소.
# api.ts 가 `${NEXT_PUBLIC_API_URL}/api` 로 요청합니다. 빈 값이면 동일 출처(/api).
#
# 단계별 전환(이 값만 바꾸면 됨):
#  - 로컬 Docker 백엔드:  http://localhost:3001
#  - AWS 배포(임시):      http://<EC2-공개IP>:3001
#  - AWS 배포(도메인):    https://api.your-domain
#
# 로컬 사용: cp .env.example .env.local
NEXT_PUBLIC_API_URL=http://localhost:3001
